{
  "manifest_version": 3,
  "name": "JLPT Page Practice Helper",
  "version": "1.1.0",
  "description": "Adds an interactive correction layer to compatible Japanesetest4you JLPT practice pages.",
  "permissions": [
    "storage",
    "clipboardWrite",
    "activeTab"
  ],
  "host_permissions": [
    "https://japanesetest4you.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://japanesetest4you.com/*"
      ],
      "js": [
        "src/contentScript.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "JLPT Page Practice Helper",
    "default_popup": "src/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "src/options.html"
}
